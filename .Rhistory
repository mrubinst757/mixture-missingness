calcstat = function(start, irate, mp, escrow, extra) {
remain = start
month = 0
ipay_total = 0
while (remain > 0) {
ipay = remain * irate / 12
remain = remain + ipay + escrow - mp - extra
month = month + 1
ipay_total = ipay_total + ipay * (ipay > 0)
}
c(round(month/12, 1), round(ipay_total,0))
}
