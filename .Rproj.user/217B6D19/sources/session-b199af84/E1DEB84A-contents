library(tidyverse)

all = map(list.files("Screening/Assignments/Results",
               pattern = "csv",
               full.names = TRUE), read_csv) %>%
  map(~set_names(.x, tolower(names(.)))) %>%
  map(~set_names(.x, gsub("ben_rec|include|include\\/exclude", "rec", names(.)))) %>%
  map(~mutate(.x, rec_num = case_when(
    grepl("include|1|unsure|[Uu]nclear|Include", as.character(rec)) ~ 1,
    grepl("Exclude|exclude|0", as.character(rec)) ~ 0
  ))) %>%
  map(~filter(.x, !is.na(title)))

all[[4]]$abstracts = NA

final = all %>%
  map(~select(.x, any_of(c("abstracts", "title", "keywords", "rec", "rec_num")))) %>%
  map(~filter(.x, rec_num == 1)) %>%
  invoke(rbind, .)

write_csv(final, "Screening/Final/full-text-review.csv")

#
all1 = all
all1[[4]] = all1[[4]] %>%
  filter(to_review == 1)

table1 = all1 %>%
  map2(c("ben", "ben", "max", "max: no abstracts", "seema"), ~mutate(.x, screener = .y)) %>%
  map(~select(.x, screener, rec_num)) %>%
  invoke(rbind, .)  %>%
  group_by(screener) %>%
  summarize(include = sum(rec_num), exclude = sum(1 - rec_num)) %>%
  mutate(total = include + exclude,
         pct_retained = round(100 * include / (include + exclude), 1)) %>%
  mutate(abstracts = if_else(!grepl("abstracts", screener), "No", "Yes"))

table2 = table1 %>%
  group_by(abstracts) %>%
  summarize(include = sum(include), exclude = sum(exclude), total = include + exclude) %>%
  mutate(pct_retained = include / total) %>%
  mutate(screener = "all")

table3 = summarize(table1, include = sum(include), exclude = sum(exclude), total = sum(total),
                   pct_retained = round(100 * include / total, 1),
                   screener = "all", abstracts = "Both")

write_csv(bind_rows(table1, table2, table3), "Screening/Final/final-rec.csv")

# data on no abstracts
all[[4]] %>%
